<h1>Vendas Recebidas</h1>
<p style="opacity:.8; margin-top:-.5rem;">Histórico completo de todas as compras feitas na loja — use para conferir comprovantes, entregas ou reclamações.</p>

<form action="/vendas_recebidas" method="get" class="filtros" style="margin:1rem 0;">
  <input type="text" name="q" placeholder="Buscar por nº do pedido, nome ou e-mail do comprador..." value="<%= @termo %>">
  <button type="submit" class="botao">Buscar</button>
  <% if @termo.present? %><a href="/vendas_recebidas" class="botao botao-secundario">Limpar</a><% end %>
</form>

<% if @vendas.empty? %>
  <p>Nenhuma venda encontrada.</p>
<% else %>
  <% @vendas.each do |venda| %>
    <div class="painel">
      <div class="pedido-cabecalho">
        <h3>Pedido #<%= venda.id %></h3>
        <span class="status-<%= venda.status %>"><%= venda.status.capitalize %></span>
      </div>
      <p class="pedido-meta">Data: <%= venda.data %> &nbsp;·&nbsp; Comprador: <%= venda.comprador ? "#{venda.comprador.nome} (#{venda.comprador.email})" : "Convidado (sem conta)" %> &nbsp;·&nbsp; Total: <strong style="color:var(--ouro)"><%= formatar_preco(venda.valor_total) %></strong></p>
      <% if venda.endereco_entrega.present? %>
        <p class="pedido-meta" style="opacity:.85;"><%= venda.endereco_entrega %></p>
      <% end %>
      <div class="tabela-wrap">
      <table class="tabela-cards">
        <thead><tr><th>Produto</th><th>Qtd.</th><th>Preço unit.</th><th>Subtotal</th></tr></thead>
        <tbody>
          <% venda.item_vendas.each do |item| %>
            <tr>
              <td data-label="Produto"><%= item.produto.nome %></td>
              <td data-label="Qtd."><%= item.quantidade %></td>
              <td data-label="Preço unit."><%= formatar_preco(item.preco_unitario) %></td>
              <td data-label="Subtotal"><%= formatar_preco(item.subtotal) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
      </div>
      <% if venda.proximo_status %>
        <form action="/vendas/<%= venda.id %>/avancar" method="post">
          <button type="submit" class="botao">Avançar para "<%= venda.proximo_status %>"</button>
        </form>
      <% else %>
        <p>Pedido finalizado.</p>
      <% end %>
    </div>
  <% end %>
<% end %>
