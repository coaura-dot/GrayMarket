<div class="hero-loja">
  <img src="/images/itens/emerald.png" alt="">
  <div>
    <h1 style="margin-bottom:4px;">Gray Market</h1>
    <p style="margin:0;">Itens de elite para dominar o servidor: netherite encantada, tridentes, maças, kits completos e muito mais.</p>
  </div>
</div>

<div class="aviso-fixo">
  <div>
    <span class="aviso-fixo-titulo">Precisa de ajuda?</span>
    <p>Caso tenha qualquer problema na compra, nos chame no discord <strong>thatsthee</strong> ou <strong>diagramxd</strong></p>
  </div>
</div>

<form action="/" method="get" class="filtros">
  <input type="text" name="q" placeholder="Buscar produto..." value="<%= @termo %>">
  <select name="categoria">
    <option value="">Todas as categorias</option>
    <% Produto::CATEGORIAS.each do |cat| %>
      <option value="<%= cat %>" <%= "selected" if @categoria == cat %>><%= cat %></option>
    <% end %>
  </select>
  <button type="submit" class="botao">Buscar</button>
</form>

<% if @produtos.empty? %>
  <p>Nenhum produto encontrado.</p>
<% else %>
  <div class="grade-produtos">
    <% @produtos.each do |produto| %>
      <div class="card-produto" data-cat="<%= produto.categoria %>">
        <a href="/produtos/<%= produto.id %>" class="card-produto-imagem">
          <img src="/images/itens/<%= icone_produto(produto) %>.png" alt="<%= produto.nome %>">
        </a>
        <% if produto.categoria %>
          <span class="categoria-tag"><%= produto.categoria %></span>
        <% end %>
        <% if produto.desconto_percentual %>
          <span class="categoria-tag" style="background:#ff5c5c; color:#fff;"><%= produto.desconto_percentual %>% OFF!</span>
        <% end %>
        <h3><a href="/produtos/<%= produto.id %>"><%= produto.nome %></a></h3>
        <p><%= produto.descricao %></p>
        <p class="preco"><%= formatar_preco(produto.preco) %></p>
        <p class="<%= "estoque-baixo" if produto.estoque <= 3 %>">Estoque: <%= produto.estoque %></p>
        <a href="/produtos/<%= produto.id %>" class="botao">Comprar agora</a>
      </div>
    <% end %>
  </div>
<% end %>
